---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ladeKommunen } from "../lib/kommunen";
import { berechneBeitrag, type Eingaben } from "../lib/berechnung";
import { euro } from "../lib/format";

const jahr = new Date().getFullYear();

// Standard-Vergleichsfall, damit unterschiedliche Modelle vergleichbar werden.
const szenario: Eingaben = {
  einkommenJahr: 45000,
  alterMonate: 40, // knapp über 3 Jahre (Kindergarten)
  wochenstunden: 35,
  anzahlKinder: 1,
};

const modellLabel: Record<string, string> = {
  beitragsfrei: "beitragsfrei",
  pauschale: "Pauschale",
  einkommensstaffel: "Einkommensstaffel",
  formel: "Formel",
};

const zeilen = ladeKommunen().map((k) => {
  const e = berechneBeitrag(k, szenario);
  const essen =
    e.essensgeld?.betrag != null
      ? e.essensgeld.betrag
      : e.essensgeld?.von != null && e.essensgeld?.bis != null
        ? (e.essensgeld.von + e.essensgeld.bis) / 2
        : null;
  return {
    name: k.name,
    slug: k.slug,
    bundesland: k.bundesland,
    modell: modellLabel[k.modell.typ] ?? k.modell.typ,
    beitrag: e.beitragMonat,
    essen,
    konfidenz: k.konfidenz,
  };
});

const title = `Kita-Gebühren im Städtevergleich ${jahr} | KitaKosten`;
const description =
  "Vergleichen Sie die Kita-Elternbeiträge deutscher Städte in einer sortierbaren Tabelle – für einen einheitlichen Beispiel-Haushalt.";
---

<BaseLayout title={title} description={description} path="/vergleich/">
  <div class="mx-auto max-w-content px-4 py-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Kita-Gebühren im Städtevergleich</h1>
    <p class="mt-3 max-w-2xl text-slate-600">
      Die Tabelle zeigt den monatlichen Elternbeitrag für einen einheitlichen Beispiel-Haushalt:
      <strong>{euro(szenario.einkommenJahr)}</strong> Bruttojahreseinkommen, ein Kind (gut 3 Jahre),
      {szenario.wochenstunden} Stunden Betreuung pro Woche. Klicken Sie auf eine Spaltenüberschrift, um zu sortieren.
    </p>

    <div class="mt-6 overflow-x-auto">
      <table id="vergleich" class="w-full min-w-[40rem] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-slate-300 text-left">
            <th scope="col" class="cursor-pointer py-3 pr-4 font-semibold" data-sort="text" data-col="0">Stadt ▲▼</th>
            <th scope="col" class="cursor-pointer py-3 pr-4 font-semibold" data-sort="text" data-col="1">Bundesland ▲▼</th>
            <th scope="col" class="cursor-pointer py-3 pr-4 font-semibold" data-sort="text" data-col="2">Modell ▲▼</th>
            <th scope="col" class="cursor-pointer py-3 pr-4 text-right font-semibold" data-sort="num" data-col="3">Beitrag/Monat ▲▼</th>
            <th scope="col" class="cursor-pointer py-3 pr-4 text-right font-semibold" data-sort="num" data-col="4">Verpflegung ▲▼</th>
          </tr>
        </thead>
        <tbody>
          {
            zeilen.map((z) => (
              <tr class="border-b border-slate-100 hover:bg-slate-50">
                <th scope="row" class="py-2 pr-4 text-left font-normal">
                  <a class="font-medium text-brand-700 hover:text-brand-800" href={`/kita-gebuehren/${z.slug}/`}>
                    {z.name}
                  </a>
                  {z.konfidenz !== "verifiziert" && (
                    <span class="ml-1 align-middle text-xs text-amber-600" title="Daten nicht abschließend verifiziert">●</span>
                  )}
                </th>
                <td class="py-2 pr-4 text-slate-600">{z.bundesland}</td>
                <td class="py-2 pr-4 text-slate-600">{z.modell}</td>
                <td class="py-2 pr-4 text-right tabular-nums" data-value={z.beitrag}>{euro(z.beitrag)}</td>
                <td class="py-2 pr-4 text-right tabular-nums" data-value={z.essen ?? -1}>
                  {z.essen != null ? euro(Math.round(z.essen)) : "–"}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="mt-4 text-xs text-slate-500">
      ● = Daten noch nicht abschließend verifiziert. Alle Angaben ohne Gewähr; maßgeblich ist die
      Satzung der jeweiligen Kommune. Die Beträge gelten nur für den oben genannten Beispiel-Haushalt.
    </p>
  </div>
</BaseLayout>

<script>
  const tabelle = document.getElementById("vergleich") as HTMLTableElement | null;
  if (tabelle) {
    const tbody = tabelle.querySelector("tbody")!;
    const richtung = new Map<number, 1 | -1>();
    tabelle.querySelectorAll<HTMLTableCellElement>("th[data-col]").forEach((th) => {
      th.addEventListener("click", () => {
        const col = Number(th.dataset.col);
        const typ = th.dataset.sort;
        const dir = (richtung.get(col) ?? 1) * -1 as 1 | -1;
        richtung.set(col, dir);
        const zeilen = Array.from(tbody.querySelectorAll("tr"));
        zeilen.sort((a, b) => {
          const za = a.children[col] as HTMLElement;
          const zb = b.children[col] as HTMLElement;
          if (typ === "num") {
            const va = Number(za.dataset.value ?? 0);
            const vb = Number(zb.dataset.value ?? 0);
            return (va - vb) * dir;
          }
          return za.textContent!.trim().localeCompare(zb.textContent!.trim(), "de") * dir;
        });
        zeilen.forEach((z) => tbody.appendChild(z));
      });
    });
  }
</script>
