---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Rechner from "../../components/Rechner.tsx";
import GebuehrenTabelle from "../../components/GebuehrenTabelle.astro";
import KonfidenzHinweis from "../../components/KonfidenzHinweis.astro";
import Disclaimer from "../../components/Disclaimer.astro";
import { ladeKommunen, aehnlicheKommunen } from "../../lib/kommunen";
import { faqFuerKommune } from "../../lib/faq";
import { datum } from "../../lib/format";

export async function getStaticPaths() {
  return ladeKommunen().map((kommune) => ({
    params: { slug: kommune.slug },
    props: { kommune },
  }));
}

const { kommune } = Astro.props;
const jahr = new Date().getFullYear();
const nachbarn = aehnlicheKommunen(kommune, 5);
const faq = faqFuerKommune(kommune);

const path = `/kita-gebuehren/${kommune.slug}/`;
const title = `Kita-Gebühren in ${kommune.name} ${jahr} – Beitrag berechnen | KitaKosten`;
const description = `Wie hoch ist der Kita-Elternbeitrag in ${kommune.name}? Jetzt kostenlos den monatlichen Beitrag nach Einkommen, Alter und Betreuungsumfang berechnen – inkl. Geschwisterrabatt und Verpflegung.`;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.frage,
    acceptedAnswer: { "@type": "Answer", text: f.antwort },
  })),
};

const appJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: `Kita-Gebührenrechner ${kommune.name}`,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
  description,
  url: new URL(path, Astro.site).href,
};
---

<BaseLayout title={title} description={description} path={path} jsonLd={[faqJsonLd, appJsonLd]}>
  <div class="mx-auto max-w-content px-4 py-8">
    <nav aria-label="Brotkrumen" class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-brand-700">Start</a>
      <span aria-hidden="true"> / </span>
      <a href="/vergleich/" class="hover:text-brand-700">Kita-Gebühren</a>
      <span aria-hidden="true"> / </span>
      <span class="text-slate-700">{kommune.name}</span>
    </nav>

    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Kita-Gebühren in {kommune.name} {jahr}
      </h1>
      <p class="mt-3 max-w-2xl text-slate-600">
        Berechnen Sie den voraussichtlichen monatlichen Elternbeitrag für die Kinderbetreuung in
        {kommune.name} ({kommune.bundesland}) – abhängig von Einkommen, Alter des Kindes,
        Betreuungsumfang und Anzahl der Kinder.
      </p>
    </header>

    {kommune.konfidenz !== "verifiziert" && (
      <div class="mb-6">
        <KonfidenzHinweis konfidenz={kommune.konfidenz} />
      </div>
    )}

    <section aria-labelledby="rechner-titel" class="mb-10 rounded-2xl border border-slate-200 p-4 sm:p-6">
      <h2 id="rechner-titel" class="mb-4 text-xl font-semibold">Beitragsrechner</h2>
      <Rechner client:load kommune={kommune} />
    </section>

    <section aria-labelledby="tabelle-titel" class="mb-10">
      <h2 id="tabelle-titel" class="mb-4 text-xl font-semibold">
        Gebührentabelle {kommune.name}
      </h2>
      <GebuehrenTabelle kommune={kommune} />
    </section>

    {kommune.hinweise && kommune.hinweise.length > 0 && (
      <section aria-labelledby="hinweise-titel" class="mb-10">
        <h2 id="hinweise-titel" class="mb-3 text-xl font-semibold">Gut zu wissen</h2>
        <ul class="list-disc space-y-2 pl-5 text-slate-700">
          {kommune.hinweise.map((h) => <li>{h}</li>)}
        </ul>
      </section>
    )}

    <section aria-labelledby="faq-titel" class="mb-10">
      <h2 id="faq-titel" class="mb-4 text-xl font-semibold">Häufige Fragen zu Kita-Gebühren in {kommune.name}</h2>
      <div class="divide-y divide-slate-200 rounded-xl border border-slate-200">
        {faq.map((f) => (
          <details class="group p-4">
            <summary class="cursor-pointer list-none font-medium text-slate-800 marker:content-none">
              <span class="flex items-center justify-between gap-2">
                {f.frage}
                <span class="text-brand-600 transition-transform group-open:rotate-45" aria-hidden="true">+</span>
              </span>
            </summary>
            <p class="mt-2 text-slate-600">{f.antwort}</p>
          </details>
        ))}
      </div>
    </section>

    <section aria-labelledby="nachbarn-titel" class="mb-10">
      <h2 id="nachbarn-titel" class="mb-4 text-xl font-semibold">Kita-Gebühren in anderen Städten</h2>
      <ul class="flex flex-wrap gap-2">
        {nachbarn.map((n) => (
          <li>
            <a
              href={`/kita-gebuehren/${n.slug}/`}
              class="inline-block rounded-full border border-slate-200 px-4 py-2 text-sm text-slate-700 hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700"
            >
              {n.name}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/vergleich/"
            class="inline-block rounded-full bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700"
          >
            Alle Städte vergleichen →
          </a>
        </li>
      </ul>
    </section>

    <Disclaimer quelleUrl={kommune.quelle_url} satzungStand={datum(kommune.satzung_stand)} />
  </div>
</BaseLayout>
