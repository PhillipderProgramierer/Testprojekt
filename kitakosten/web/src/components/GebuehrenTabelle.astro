---
import type { Kommune } from "../lib/gebuehrenmodell";
import { euro } from "../lib/format";

export interface Props {
  kommune: Kommune;
}
const { kommune } = Astro.props;
const modell = kommune.modell;

function einkommenLabel(von: number, bis: number | null): string {
  if (von === 0 && bis !== null) return `bis ${euro(bis)}`;
  if (bis === null) return `ab ${euro(von)}`;
  return `${euro(von)} – ${euro(bis)}`;
}
---

<div class="overflow-x-auto">
  {
    modell.typ === "beitragsfrei" && (
      <p class="rounded-lg bg-brand-50 p-4 text-slate-700">
        Die Kindertagesbetreuung ist in {kommune.name} beitragsfrei.
        {modell.beschreibung && <span class="mt-1 block text-sm text-slate-500">{modell.beschreibung}</span>}
      </p>
    )
  }

  {
    modell.typ === "pauschale" && (
      <table class="w-full min-w-[32rem] border-collapse text-sm">
        <caption class="sr-only">Monatliche Elternbeiträge in {kommune.name} nach Betreuungsumfang und Alter</caption>
        <thead>
          <tr class="border-b border-slate-300 text-left">
            <th scope="col" class="py-2 pr-4 font-semibold">Betreuungsumfang</th>
            {modell.altersgruppen.map((g) => (
              <th scope="col" class="py-2 pr-4 text-right font-semibold">{g.label}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {modell.betreuungsstufen.map((s) => (
            <tr class="border-b border-slate-100">
              <th scope="row" class="py-2 pr-4 text-left font-normal text-slate-700">{s.label}</th>
              {modell.altersgruppen.map((g) => (
                <td class="py-2 pr-4 text-right tabular-nums">{euro(s.betraege[g.key] ?? 0)}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    )
  }

  {
    modell.typ === "einkommensstaffel" &&
      modell.einkommensstufen[0].betreuungsstufen.map((_, stufenIndex) => {
        const stufenLabel = modell.einkommensstufen[0].betreuungsstufen[stufenIndex].label;
        return (
          <div class="mb-8">
            <h3 class="mb-2 text-base font-semibold text-slate-800">Betreuung: {stufenLabel}</h3>
            <table class="w-full min-w-[32rem] border-collapse text-sm">
              <caption class="sr-only">
                Elternbeiträge in {kommune.name} nach {modell.einkommensbasis}jahreseinkommen für {stufenLabel}
              </caption>
              <thead>
                <tr class="border-b border-slate-300 text-left">
                  <th scope="col" class="py-2 pr-4 font-semibold">
                    {modell.einkommensbasis === "netto" ? "Netto" : "Brutto"}jahreseinkommen
                  </th>
                  {modell.altersgruppen.map((g) => (
                    <th scope="col" class="py-2 pr-4 text-right font-semibold">{g.label}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {modell.einkommensstufen.map((es) => {
                  const bs = es.betreuungsstufen[stufenIndex];
                  return (
                    <tr class="border-b border-slate-100">
                      <th scope="row" class="py-2 pr-4 text-left font-normal text-slate-700">
                        {einkommenLabel(es.von, es.bis)}
                      </th>
                      {modell.altersgruppen.map((g) => (
                        <td class="py-2 pr-4 text-right tabular-nums">{euro(bs.betraege[g.key] ?? 0)}</td>
                      ))}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        );
      })
  }

  {
    modell.typ === "formel" && (
      <div class="space-y-4 text-sm text-slate-700">
        <p>
          Der Beitrag beträgt <strong>{modell.prozentsatz} %</strong> des
          {modell.basis === "monat" ? " monatlichen " : " jährlichen "}
          {modell.einkommensbasis === "netto" ? "Netto" : "Brutto"}einkommens, mindestens
          <strong> {euro(modell.min)}</strong> und höchstens <strong>{euro(modell.max)}</strong> pro Monat.
        </p>
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <h3 class="mb-1 font-semibold text-slate-800">Faktor nach Alter</h3>
            <table class="w-full border-collapse">
              <tbody>
                {modell.altersgruppen.map((g) => (
                  <tr class="border-b border-slate-100">
                    <th scope="row" class="py-1 pr-4 text-left font-normal">{g.label}</th>
                    <td class="py-1 text-right tabular-nums">× {modell.altersfaktoren?.[g.key] ?? 1}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {modell.betreuungsfaktoren && modell.betreuungsfaktoren.length > 0 && (
            <div>
              <h3 class="mb-1 font-semibold text-slate-800">Faktor nach Betreuungsumfang</h3>
              <table class="w-full border-collapse">
                <tbody>
                  {modell.betreuungsfaktoren.map((bf) => (
                    <tr class="border-b border-slate-100">
                      <th scope="row" class="py-1 pr-4 text-left font-normal">{bf.label}</th>
                      <td class="py-1 text-right tabular-nums">× {bf.faktor}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    )
  }
</div>
