---
const links = [
  { href: "/", label: "Start" },
  { href: "/vergleich/", label: "Städtevergleich" },
  { href: "/ratgeber/", label: "Ratgeber" },
];
const pfad = Astro.url.pathname;
---

<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-content items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2 font-bold text-brand-800">
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white"
        aria-hidden="true">€</span
      >
      <span>KitaKosten</span>
    </a>
    <nav aria-label="Hauptnavigation">
      <ul class="flex gap-1 text-sm">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  "rounded-lg px-3 py-2 font-medium transition-colors hover:bg-brand-50 hover:text-brand-700",
                  pfad === l.href ? "text-brand-700" : "text-slate-600",
                ]}
                aria-current={pfad === l.href ? "page" : undefined}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
