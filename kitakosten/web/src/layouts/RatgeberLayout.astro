---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    aktualisiert?: string;
  };
}
const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} | KitaKosten Ratgeber`} description={frontmatter.description}>
  <article class="mx-auto max-w-3xl px-4 py-8">
    <nav aria-label="Brotkrumen" class="mb-4 text-sm text-slate-500">
      <a href="/" class="hover:text-brand-700">Start</a>
      <span aria-hidden="true"> / </span>
      <a href="/ratgeber/" class="hover:text-brand-700">Ratgeber</a>
    </nav>
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{frontmatter.title}</h1>
    {frontmatter.aktualisiert && (
      <p class="mt-2 text-sm text-slate-500">Zuletzt aktualisiert: {frontmatter.aktualisiert}</p>
    )}
    <div class="artikel mt-6">
      <slot />
    </div>
    <p class="mt-10 rounded-xl bg-slate-50 p-4 text-sm text-slate-500">
      Dieser Ratgeber dient der allgemeinen Information und ersetzt keine Rechtsberatung. Maßgeblich
      ist die jeweils aktuelle Satzung Ihrer Kommune.
    </p>
  </article>
</BaseLayout>
