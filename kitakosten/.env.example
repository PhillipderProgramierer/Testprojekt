# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env ist gitignored und darf niemals committet werden.

# --- Datenpipeline (Python) ---
# API-Key für die Anthropic-API (extract.py). Pflicht für 'python -m pipeline extract'.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Modell für die Extraktion (Standard: claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Kontakt-Mail, die fetch.py im User-Agent mitsendet (Netiquette beim Crawlen).
KITAKOSTEN_CONTACT=kontakt@ihre-domain.de

# --- Website / Build ---
# Öffentliche Basis-URL (für kanonische URLs und die Sitemap). Standard: https://kitakosten.de
SITE_URL=https://kitakosten.de

# --- Deployment (nur in GitHub Actions als Secrets/Variables hinterlegen) ---
# Diese Werte gehören NICHT in eine lokale .env, sondern in die GitHub-Repo-Einstellungen:
#   Settings -> Secrets and variables -> Actions
# Secrets:   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
# Variables: CLOUDFLARE_PROJECT_NAME (z. B. kitakosten), SITE_URL
